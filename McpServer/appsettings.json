{
  //"StartupCulture": "en-US",

  // AllowInsecureSsl: skip SSL certificate validation (development only)
  "AllowInsecureSsl": true,

  "ApiSettings": {
    // BaseUrl: the backend url
    "BaseUrl": "https://localhost",

    // Port: the backend port
    "Port": 44354,

    // Timeout: the backend request timeout (timespan: default is 100 seconds)
    //"Timeout": "00:05:00",

    // ApiKey: the backend api key — use apisettings.json for secrets (dev only)
    //"ApiKey": "???????"
  },

  // NOTE: Console sink is intentionally omitted.
  // The MCP server communicates via stdio — any output to stdout corrupts the MCP protocol.
  // All logging must go to file only.
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "pathWindows": "%PROGRAMDATA%/PayrollEngine/McpServer/logs/log-.log",
                "path": "logs/log-.log",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 7,
                "buffered": false,
                "restrictedToMinimumLevel": "Information"
              }
            }
          ]
        }
      }
    ]
  }
}
