{
  //"StartupCulture": "en-US",

  // AllowInsecureSsl: skip SSL certificate validation (development only)
  "AllowInsecureSsl": true,

  "McpServer": {
    // IsolationLevel: controls data access scope for every tool call.
    // MultiTenant (default) — full access across all tenants.
    // Tenant                — all tool calls are scoped to TenantIdentifier.
    // Division              — scoped to DivisionName within TenantIdentifier.
    // Employee              — scoped to EmployeeIdentifier within TenantIdentifier.
    "IsolationLevel": "Tenant",

    // TenantIdentifier: required when IsolationLevel is Tenant, Division, or Employee.
    "TenantIdentifier": "ACME.International",

    // DivisionName: required when IsolationLevel is Division.
    //DivisionName": "ACME.DE",

    // EmployeeIdentifier: required when IsolationLevel is Employee.
    //"EmployeeIdentifier": "anna.weber@acme-international.com",

    // PreviewUserIdentifier: service account user for get_employee_pay_preview and execute_payroll_report.
    // The user must exist in the target tenant.
    //"PreviewUserIdentifier": "mcp-service@acme.com"

    "Permissions": {
      "HR": "Read",
      "Payroll": "Read",
      "Report": "Read",
      "System": "Read"
    }
  },

  "ApiSettings": {
    // BaseUrl: the backend url
    "BaseUrl": "https://localhost",

    // Port: the backend port
    "Port": 44354,

    // Timeout: the backend request timeout (timespan: default is 100 seconds).
    // The default is sufficient for all tools including get_employee_pay_preview.
    //"Timeout": "00:01:40",

    // ApiKey: the backend api key — use apisettings.json for secrets (dev only)
    //"ApiKey": "???????"
  },

  // NOTE: Console sink is intentionally omitted.
  // The MCP server communicates via stdio — any output to stdout corrupts the MCP protocol.
  // All logging must go to file only.
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "C:/ProgramData/PayrollEngine/McpServer/logs/log-.log",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 7,
                "buffered": false,
                "restrictedToMinimumLevel": "Information"
              }
            }
          ]
        }
      }
    ]
  }
}
