{
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "logo.svg",
          "favicon.ico"
        ]
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appTitle": "PE MCP Server Reference"
    },
    "template": [
      "default",
      "templates/darkerfx"
    ],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
